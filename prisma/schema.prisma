generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  telegramId   String   @unique
  firstName    String?
  lastName     String?
  username     String?
  photoUrl     String?
  trustScore   Int      @default(0)
  reports      Report[]
  createdAt    DateTime @default(now())
}

model Station {
  id          String   @id @default(cuid())
  externalId  String   @unique
  name        String
  type        String
  lat         Float
  lon         Float
  reports     Report[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Report {
  id          String   @id @default(cuid())
  stationId   String
  station     Station  @relation(fields: [stationId], references: [id])
  
  fuelType    String   // 'Benzene', 'Gasoline', 'Electric'
  status      String   // 'Available', 'Out of Stock'
  queue       String   // 'No Line', 'Short', 'Medium', 'Long'
  
  // Trust System
  upvotes     Int      @default(0)
  downvotes   Int      @default(0)
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model GlobalPrice {
  id          String   @id @default(cuid())
  fuelType    String   @unique // 'Benzene', 'Gasoline', 'Electric'
  price       Float
  unit        String   // 'ETB/L', 'ETB/kWh'
  updatedAt   DateTime @updatedAt
}
